# Front-end build configuration.
# NOTE: The OpenAI key is NOT here anymore — it lives in backend/.env and never
# ships inside the app. The front-end only needs to know where the backend is.

# URL of the hosted backend that proxies OpenAI.
# Local dev default: http://localhost:8787
# Production example: https://api.numerologistai.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
