# Backend secrets — NEVER commit the real .env or ship these to the app.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Port the API listens on
PORT=8787

# Comma-separated web origins allowed to call the API (the hosted web build).
# Leave empty during local dev to allow all. Native mobile apps are always allowed.
# Example: ALLOWED_ORIGINS=https://numerologistai.com,https://www.numerologistai.com
ALLOWED_ORIGINS=

# Keep-alive: set to this service's public URL so it pings its own /health and
# stays warm on free hosts. Example: SELF_URL=https://numerologistai-api.onrender.com
SELF_URL=
# How often to self-ping, in milliseconds (default 14 minutes).
KEEP_ALIVE_MS=840000
